{
  "name": "setup-sops action",
  "image": "mcr.microsoft.com/devcontainers/universal:4-linux",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers-extra/features/sops:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "GitHub.vscode-github-actions",
        "redhat.vscode-yaml"
      ]
    }
  },
  "remoteEnv": {
    "SOPS_EDITOR": "code --wait"
  }
}
